// --ENUMS--
enum OrderStatus{
  PENDING
  PREPARING
  READY_FOR_PICKUP
  IN_TRANSIT
  DELIVERED
  CANCELLED 
}

// --MODELS--
model Order {
  orderId           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  owner             User         @relation(fields: [ownerId], references: [id])
  ownerId           String
  orderedItems      OrderItem[]
  deliveryStatus    OrderStatus   @default(PENDING)
  totalPrice        Float
  payment           String         @default("card")
  deliveryAddress   String
  deliveryPhone     String
  estimatedDeliveryAt DateTime     @default(dbgenerated("(now() + interval '45 minutes')"))
  isPaid            Boolean        @default(false)
  paidAt            DateTime?
  isDelivered       Boolean        @default(false)
  deliveredAt       DateTime?
  paymentReference  String?
  paystackAccessCode String?
  paymentStatus     String         @default("pending")
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt(now())
  status            OrderStatus     @default(PENDING)

  @@index(orderId)
  @@index(ownerId)

}



model OrderItem {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order     Order   @relation(fields: [orderId], references: [orderId])
  orderId   String
  itemName  String
  quantity  Int
  price     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt(now())
}